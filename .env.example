# Knows benchmark credentials — copy to .env (gitignored) and fill in.
# Validate the result with:  python scripts/setup_env.py

# --- Google browser account (REQUIRED) ---------------------------------
# The Google account the agent signs in with to drive Docs/Sheets/Slides.
# Must NOT have 2FA/passkeys enforced (see SETUP_AUTH.md).
export GOOGLE_USER_EMAIL=you@gmail.com
export GOOGLE_USER_PASSWORD=your-password

# --- Model API keys (each optional — only for the models you run) ------
export OPENAI_API_KEY=          # gpt55_* benchmark scripts
export ANTHROPIC_API_KEY=       # opus47_* benchmark scripts
export DEEPSEEK_API_KEY=        # deepseek_v4_* benchmark scripts
export GEMINI_API_KEY=          # gemini31_* benchmark scripts

# --- Evaluator service account (optional override) ---------------------
# Defaults to browsergym/knows/auth-data/service-account.json. This is the
# Drive/Docs/Sheets/Slides API credential used for grading — unrelated to
# the browser login above.
# export SERVICE_ACCOUNT_PATH=
